# =============================================================================
# Onera Operator - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://onera:onera@localhost:5432/onera

# -----------------------------------------------------------------------------
# Redis (for BullMQ task queue)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
# Supported providers: openai | azure | anthropic | openai-compatible
AI_PROVIDER=openai
AI_MODEL=gpt-4o
AI_API_KEY=sk-your-api-key-here

# Only needed for openai-compatible or local models
AI_BASE_URL=

# Only needed for Azure OpenAI (use AI_BASE_URL instead if you have the full endpoint)
AI_AZURE_RESOURCE_NAME=
AI_AZURE_DEPLOYMENT_NAME=

# Premium (frontier) model — used for quality-critical agents (chat, outreach,
# research, engineer). Leave empty to use the default model for everything.
# Shares the same provider/key/baseURL unless overridden with AI_PREMIUM_* vars.
AI_PREMIUM_MODEL=
# AI_PREMIUM_PROVIDER=azure
# AI_PREMIUM_API_KEY=
# AI_PREMIUM_BASE_URL=
# AI_PREMIUM_AZURE_RESOURCE_NAME=
# AI_PREMIUM_AZURE_DEPLOYMENT_NAME=  # Must match the Azure deployment name (not the model name)

# -----------------------------------------------------------------------------
# Email (Azure Email Communication Service)
# -----------------------------------------------------------------------------
# Azure ECS connection string from: az communication list-key --name <name> --resource-group <rg>
# Used for: outreach emails, daily digest sent to founders
AZURE_EMAIL_CONNECTION_STRING=
AZURE_EMAIL_SENDER=operator@onera.app

# Azure Service Principal — needed to provision per-company sender emails (e.g. companyname@onera.app)
# Create with: az ad sp create-for-rbac --name "onera-operator-backend" --role Contributor --scopes /subscriptions/<sub>/resourceGroups/<rg>
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Web Search (Serper — https://serper.dev)
# -----------------------------------------------------------------------------
# Primary search engine (Google results). Falls back to DuckDuckGo if unset or exhausted.
# Free tier: 2,500 searches. Get key at https://serper.dev
SERPER_API_KEY=

# -----------------------------------------------------------------------------
# Deep Web Crawling (Crawl4AI — https://crawl4ai.com)
# -----------------------------------------------------------------------------
# Run Crawl4AI locally: docker run -p 11235:11235 unclecode/crawl4ai:latest
# Or use docker-compose (includes crawl4ai service)
# Leave empty to use basic fetch-based scraper
CRAWL4AI_API_URL=http://localhost:11235

# -----------------------------------------------------------------------------
# Sandboxed Code Execution (E2B — https://e2b.dev)
# -----------------------------------------------------------------------------
# Get your API key at: https://e2b.dev/dashboard
# Used by the engineering agent to run code safely in isolated sandboxes
E2B_API_KEY=

# -----------------------------------------------------------------------------
# Twitter/X (for real tweet posting)
# -----------------------------------------------------------------------------
# Create a Twitter Developer app at: https://developer.twitter.com
# Requires "Read and Write" permissions
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# Authentication (Clerk — https://clerk.com)
# -----------------------------------------------------------------------------
# Create an app at: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/new

# -----------------------------------------------------------------------------
# Billing (DodoPayments — https://dodopayments.com)
# -----------------------------------------------------------------------------
# API key from: https://app.dodopayments.com/settings/api-keys
# Same key works for both test and live — the ENVIRONMENT var controls the mode
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=whsec_...
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_RETURN_URL=http://localhost:3000/dashboard?billing=success
# Live-mode product IDs (only needed when DODO_PAYMENTS_ENVIRONMENT=live_mode)
DODO_SUBSCRIPTION_PRODUCT_ID=
DODO_GROWTH_PRODUCT_ID=
DODO_SCALE_PRODUCT_ID=
DODO_POWER_PRODUCT_ID=
DODO_MEGA_PRODUCT_ID=

# -----------------------------------------------------------------------------
# Agent Loop Scheduling
# -----------------------------------------------------------------------------
# Cron expression for the autonomous agent loop (default: every 4 hours)
AGENT_LOOP_INTERVAL_CRON=0 */4 * * *

# Cron expression for daily report generation (default: 6 PM daily)
DAILY_REPORT_CRON=0 18 * * *

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
