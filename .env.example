# =============================================================================
# Onera Operator - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://onera:onera@localhost:5432/onera

# -----------------------------------------------------------------------------
# Redis (for BullMQ task queue)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
# Supported providers: openai | azure | anthropic | openai-compatible
AI_PROVIDER=openai
AI_MODEL=gpt-4o
AI_API_KEY=sk-your-api-key-here

# Only needed for openai-compatible or local models
AI_BASE_URL=

# Only needed for Azure OpenAI (use AI_BASE_URL instead if you have the full endpoint)
AI_AZURE_RESOURCE_NAME=
AI_AZURE_DEPLOYMENT_NAME=

# -----------------------------------------------------------------------------
# Web Search (Exa API — https://exa.ai)
# -----------------------------------------------------------------------------
# Get your API key at: https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# -----------------------------------------------------------------------------
# Email (Resend — https://resend.com)
# -----------------------------------------------------------------------------
# Get your API key at: https://resend.com/api-keys
# Used for: outreach emails, daily digest sent to founders
RESEND_API_KEY=
RESEND_FROM_EMAIL=Onera Operator <operator@yourdomain.com>

# -----------------------------------------------------------------------------
# Deep Web Crawling (Crawl4AI — https://crawl4ai.com)
# -----------------------------------------------------------------------------
# Run Crawl4AI locally: docker run -p 11235:11235 unclecode/crawl4ai:latest
# Or use docker-compose (includes crawl4ai service)
# Leave empty to use basic fetch-based scraper
CRAWL4AI_API_URL=http://localhost:11235

# -----------------------------------------------------------------------------
# Sandboxed Code Execution (E2B — https://e2b.dev)
# -----------------------------------------------------------------------------
# Get your API key at: https://e2b.dev/dashboard
# Used by the engineering agent to run code safely in isolated sandboxes
E2B_API_KEY=

# -----------------------------------------------------------------------------
# Twitter/X (for real tweet posting)
# -----------------------------------------------------------------------------
# Create a Twitter Developer app at: https://developer.twitter.com
# Requires "Read and Write" permissions
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# Authentication (Clerk — https://clerk.com)
# -----------------------------------------------------------------------------
# Create an app at: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/new

# -----------------------------------------------------------------------------
# Agent Loop Scheduling
# -----------------------------------------------------------------------------
# Cron expression for the autonomous agent loop (default: every 4 hours)
AGENT_LOOP_INTERVAL_CRON=0 */4 * * *

# Cron expression for daily report generation (default: 6 PM daily)
DAILY_REPORT_CRON=0 18 * * *

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
