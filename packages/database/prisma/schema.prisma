datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Auth ────────────────────────────────────────────────────────

model User {
  id        String   @id // Clerk user ID
  name      String?
  email     String?  @unique
  image     String?
  credits   Int      @default(100) // Free starting credits
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects Project[]

  @@map("users")
}

// ─── Core Models ─────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  product     String?
  targetUsers String?  @map("target_users")
  competitors String?
  goals       String?
  website     String?
  logoUrl     String?  @map("logo_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tasks   Task[]
  reports DailyReport[]

  @@index([userId])
  @@map("projects")
}

model Task {
  id           String       @id @default(cuid())
  projectId    String       @map("project_id")
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  description  String
  category     TaskCategory
  priority     TaskPriority
  status       TaskStatus   @default(PENDING)
  automatable  Boolean      @default(false)
  agentName    String?      @map("agent_name")
  result       String?
  credits      Int          @default(1) // Credits consumed by this task
  scheduledFor DateTime?    @map("scheduled_for")
  scheduledAt  String?      @map("scheduled_at") // e.g. "Tonight", "Weekdays"
  completedAt  DateTime?    @map("completed_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  executionLogs ExecutionLog[]

  @@index([projectId])
  @@index([status])
  @@index([category])
  @@map("tasks")
}

model ExecutionLog {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agentName String   @map("agent_name")
  action    String
  input     String?
  output    String?
  status    String   // "success" | "error"
  duration  Int?     // milliseconds
  createdAt DateTime @default(now()) @map("created_at")

  @@index([taskId])
  @@map("execution_logs")
}

model AgentStatus {
  id             String    @id @default(cuid())
  name           String    @unique
  displayName    String    @map("display_name")
  status         String    @default("idle") // "idle" | "running" | "error"
  lastRunAt      DateTime? @map("last_run_at")
  lastError      String?   @map("last_error")
  tasksCompleted Int       @default(0) @map("tasks_completed")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("agent_statuses")
}

model DailyReport {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  day            Int      @default(1) // Day number since project creation
  date           DateTime @default(now())
  content        String
  tasksCompleted String?  @map("tasks_completed")
  tasksPlanned   String?  @map("tasks_planned")
  metrics        String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([date])
  @@map("daily_reports")
}

enum TaskCategory {
  GROWTH
  MARKETING
  OUTREACH
  PRODUCT
  ANALYTICS
  OPERATIONS
  RESEARCH
  ENGINEERING
  TWITTER
}

enum TaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}
