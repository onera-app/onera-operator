datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Auth ────────────────────────────────────────────────────────

model User {
  id               String    @id // Clerk user ID
  name             String?
  email            String?   @unique
  image            String?
  credits            Int       @default(0)
  dodoCustomerId     String?   @unique @map("dodo_customer_id")
  dodoSubscriptionId String?   @unique @map("dodo_subscription_id")
  subscriptionStatus String?   @map("subscription_status") // "active" | "on_hold" | "cancelled" | "expired" | "trialing"
  trialActivated     Boolean   @default(false) @map("trial_activated")
  trialEndsAt        DateTime? @map("trial_ends_at")
  autoChargeEnabled  Boolean   @default(true) @map("auto_charge_enabled")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  projects          Project[]
  creditTransactions CreditTransaction[]

  @@map("users")
}

model CreditTransaction {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            CreditTransactionType
  amount          Int      // positive = credit added, negative = credit deducted
  balance         Int      // balance after transaction
  description     String
  dodoPaymentId   String?  @map("dodo_payment_id")
  packSlug        String?  @map("pack_slug") // e.g. "growth-500", "scale-2000"
  taskId          String?  @map("task_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("credit_transactions")
}

enum CreditTransactionType {
  CARD_BONUS           // 50 free credits when user subscribes (trial start)
  PURCHASE             // Bought a credit pack (one-time top-up)
  AUTO_CHARGE          // Auto-charged when credits ran out
  SUBSCRIPTION_RENEWAL // Monthly subscription renewal (500 credits)
  TASK_DEDUCTION       // Credits deducted for a task
  REFUND               // Refund from failed task
  MANUAL               // Admin adjustment
}

// ─── Core Models ─────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  product     String?
  targetUsers String?  @map("target_users")
  competitors String?
  goals       String?
  website      String?
  companyEmail String?  @unique @map("company_email")
  logoUrl      String?  @map("logo_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tasks      Task[]
  reports    DailyReport[]
  tweetQueue TweetQueue[]
  emailLogs  EmailLog[]

  @@index([userId])
  @@map("projects")
}

model Task {
  id           String       @id @default(cuid())
  projectId    String       @map("project_id")
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  description  String
  category     TaskCategory
  priority     TaskPriority
  status       TaskStatus   @default(PENDING)
  automatable  Boolean      @default(false)
  agentName    String?      @map("agent_name")
  result       String?
  summary      String?      // Human-readable one-line summary generated by Kimi after completion
  credits      Int          @default(1) // Credits: tweet=3, outreach/research=8, engineer=10, plan=1
  retryCount   Int          @default(0) @map("retry_count") // Auto-retry counter for stale task recovery
  scheduledFor DateTime?    @map("scheduled_for")
  scheduledAt  String?      @map("scheduled_at") // e.g. "Tonight", "Weekdays"
  completedAt  DateTime?    @map("completed_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  executionLogs ExecutionLog[]

  @@index([projectId])
  @@index([status])
  @@index([category])
  @@map("tasks")
}

model ExecutionLog {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agentName String   @map("agent_name")
  action    String
  input     String?
  output    String?
  status    String   // "success" | "error"
  duration  Int?     // milliseconds
  createdAt DateTime @default(now()) @map("created_at")

  @@index([taskId])
  @@map("execution_logs")
}

model AgentStatus {
  id             String    @id @default(cuid())
  name           String    @unique
  displayName    String    @map("display_name")
  status         String    @default("idle") // "idle" | "running" | "error"
  lastRunAt      DateTime? @map("last_run_at")
  lastError      String?   @map("last_error")
  tasksCompleted Int       @default(0) @map("tasks_completed")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("agent_statuses")
}

model DailyReport {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  day            Int      @default(1) // Day number since project creation
  date           DateTime @default(now())
  content        String
  tasksCompleted String?  @map("tasks_completed")
  tasksPlanned   String?  @map("tasks_planned")
  metrics        String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([date])
  @@map("daily_reports")
}

model TweetQueue {
  id          String           @id @default(cuid())
  projectId   String           @map("project_id")
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content     String
  tone        String           @default("sharp")
  status      TweetQueueStatus @default(PENDING)
  tweetUrl    String?          @map("tweet_url")
  generatedAt DateTime         @default(now()) @map("generated_at")
  postedAt    DateTime?        @map("posted_at")
  postedBy    String?          @map("posted_by")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([status])
  @@index([projectId])
  @@map("tweet_queue")
}

model EmailLog {
  id             String         @id @default(cuid())
  projectId      String         @map("project_id")
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  azureMessageId String?        @map("azure_message_id")
  fromEmail      String         @map("from_email")
  toEmail        String         @map("to_email")
  replyTo        String?        @map("reply_to")
  subject        String
  body           String
  status         EmailLogStatus @default(SENT)
  errorMessage   String?        @map("error_message")
  type           EmailLogType   @default(OUTREACH)
  sentAt         DateTime       @default(now()) @map("sent_at")

  @@index([projectId])
  @@index([status])
  @@index([sentAt])
  @@map("email_logs")
}

enum EmailLogStatus {
  SENT
  FAILED
  BLOCKED
}

enum EmailLogType {
  OUTREACH
  DIGEST
  NOTIFICATION
}

enum TaskCategory {
  GROWTH
  MARKETING
  OUTREACH
  PRODUCT
  ANALYTICS
  OPERATIONS
  RESEARCH
  ENGINEERING
  TWITTER
}

enum TaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum TweetQueueStatus {
  PENDING
  POSTED
  DELETED
}
