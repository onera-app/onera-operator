datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Auth ────────────────────────────────────────────────────────

model User {
  id               String    @id // Clerk user ID
  name             String?
  email            String?   @unique
  image            String?
  credits            Int       @default(0)
  dodoCustomerId     String?   @unique @map("dodo_customer_id")
  dodoSubscriptionId String?   @unique @map("dodo_subscription_id")
  subscriptionStatus String?   @map("subscription_status") // "active" | "on_hold" | "cancelled" | "expired" | "trialing"
  trialActivated     Boolean   @default(false) @map("trial_activated")
  trialEndsAt        DateTime? @map("trial_ends_at")
  autoChargeEnabled  Boolean   @default(true) @map("auto_charge_enabled")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  projects          Project[]
  creditTransactions CreditTransaction[]

  @@map("users")
}

model CreditTransaction {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            CreditTransactionType
  amount          Int      // positive = credit added, negative = credit deducted
  balance         Int      // balance after transaction
  description     String
  dodoPaymentId   String?  @map("dodo_payment_id")
  packSlug        String?  @map("pack_slug") // e.g. "growth-500", "scale-2000"
  taskId          String?  @map("task_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("credit_transactions")
}

enum CreditTransactionType {
  SIGNUP_BONUS         // 200 free credits on first signup
  CARD_BONUS           // 50 free credits when user subscribes (trial start)
  PURCHASE             // Bought a credit pack (one-time top-up)
  AUTO_CHARGE          // Auto-charged when credits ran out
  SUBSCRIPTION_RENEWAL // Monthly subscription renewal (500 credits)
  TASK_DEDUCTION       // Credits deducted for a task
  REFUND               // Refund from failed task
  MANUAL               // Admin adjustment
}

// ─── Core Models ─────────────────────────────────────────────────

enum ProjectType {
  COMPANY
  INDIVIDUAL
}

model Project {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        ProjectType @default(COMPANY) @map("project_type")
  description String?
  product     String?
  targetUsers String?     @map("target_users")
  competitors String?
  goals       String?
  website      String?
  companyEmail String?    @unique @map("company_email")
  logoUrl      String?    @map("logo_url")
  paused       Boolean    @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tasks              Task[]
  reports            DailyReport[]
  tweetQueue         TweetQueue[]
  emailLogs          EmailLog[]
  contacts           Contact[]
  emailConversations EmailConversation[]

  @@index([userId])
  @@map("projects")
}

model Task {
  id           String       @id @default(cuid())
  projectId    String       @map("project_id")
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  description  String
  category     TaskCategory
  priority     TaskPriority
  status       TaskStatus   @default(PENDING)
  automatable  Boolean      @default(false)
  agentName    String?      @map("agent_name")
  result       String?
  summary      String?      // Human-readable one-line summary generated by Kimi after completion
  credits      Int          @default(1) // Credits: tweet=3, outreach/research=8, engineer=10, plan=1
  retryCount   Int          @default(0) @map("retry_count") // Auto-retry counter for stale task recovery
  scheduledFor DateTime?    @map("scheduled_for")
  scheduledAt  String?      @map("scheduled_at") // e.g. "Tonight", "Weekdays"
  completedAt  DateTime?    @map("completed_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  executionLogs ExecutionLog[]

  @@index([projectId])
  @@index([status])
  @@index([category])
  @@map("tasks")
}

model ExecutionLog {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agentName String   @map("agent_name")
  action    String
  input     String?
  output    String?
  status    String   // "success" | "error"
  duration  Int?     // milliseconds
  createdAt DateTime @default(now()) @map("created_at")

  @@index([taskId])
  @@map("execution_logs")
}

model AgentStatus {
  id             String    @id @default(cuid())
  name           String    @unique
  displayName    String    @map("display_name")
  status         String    @default("idle") // "idle" | "running" | "error"
  lastRunAt      DateTime? @map("last_run_at")
  lastError      String?   @map("last_error")
  tasksCompleted Int       @default(0) @map("tasks_completed")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("agent_statuses")
}

model DailyReport {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  day            Int      @default(1) // Day number since project creation
  date           DateTime @default(now())
  content        String
  tasksCompleted String?  @map("tasks_completed")
  tasksPlanned   String?  @map("tasks_planned")
  metrics        String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([date])
  @@map("daily_reports")
}

model TweetQueue {
  id          String           @id @default(cuid())
  projectId   String           @map("project_id")
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content     String
  tone        String           @default("sharp")
  status      TweetQueueStatus @default(PENDING)
  tweetUrl    String?          @map("tweet_url")
  generatedAt DateTime         @default(now()) @map("generated_at")
  postedAt    DateTime?        @map("posted_at")
  postedBy    String?          @map("posted_by")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([status])
  @@index([projectId])
  @@map("tweet_queue")
}

model Contact {
  id          String        @id @default(cuid())
  projectId   String        @map("project_id")
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  email       String
  name        String?
  company     String?
  role        String?
  companyUrl  String?       @map("company_url")
  source      ContactSource @default(OUTREACH)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  conversations EmailConversation[]
  emailLogs     EmailLog[]

  @@unique([projectId, email])
  @@index([projectId])
  @@index([email])
  @@map("contacts")
}

enum ContactSource {
  OUTREACH
  MANUAL
  INBOUND
}

model EmailConversation {
  id             String             @id @default(cuid())
  projectId      String             @map("project_id")
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contactId      String             @map("contact_id")
  contact        Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  subject        String
  status         ConversationStatus @default(ACTIVE)
  lastActivityAt DateTime           @default(now()) @map("last_activity_at")
  messageCount   Int                @default(0) @map("message_count")
  createdAt      DateTime           @default(now()) @map("created_at")

  emailLogs EmailLog[]

  @@index([projectId])
  @@index([contactId])
  @@index([status])
  @@index([lastActivityAt])
  @@map("email_conversations")
}

enum ConversationStatus {
  ACTIVE
  REPLIED
  FOLLOW_UP
  CLOSED
}

model EmailLog {
  id              String              @id @default(cuid())
  projectId       String              @map("project_id")
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversationId  String?             @map("conversation_id")
  conversation    EmailConversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  contactId       String?             @map("contact_id")
  contact         Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)
  azureMessageId  String?             @map("azure_message_id")
  messageId       String?             @unique @map("message_id")       // RFC 5322 Message-ID header
  inReplyTo       String?             @map("in_reply_to")              // Parent message's Message-ID
  references      String?                                               // Full References header chain
  fromEmail       String              @map("from_email")
  toEmail         String              @map("to_email")
  replyTo         String?             @map("reply_to")
  subject         String
  body            String
  htmlBody        String?             @map("html_body")
  direction       EmailDirection      @default(OUTBOUND)
  status          EmailLogStatus      @default(SENT)
  deliveryStatus  EmailDeliveryStatus @default(PENDING) @map("delivery_status")
  errorMessage    String?             @map("error_message")
  type            EmailLogType        @default(OUTREACH)
  sentAt          DateTime            @default(now()) @map("sent_at")

  @@index([projectId])
  @@index([conversationId])
  @@index([contactId])
  @@index([status])
  @@index([deliveryStatus])
  @@index([direction])
  @@index([sentAt])
  @@index([messageId])
  @@index([toEmail])
  @@map("email_logs")
}

enum EmailDirection {
  OUTBOUND
  INBOUND
}

enum EmailLogStatus {
  SENT
  FAILED
  BLOCKED
}

enum EmailDeliveryStatus {
  PENDING
  DELIVERED
  BOUNCED
  OPENED
  CLICKED
  FAILED
}

enum EmailLogType {
  OUTREACH
  DIGEST
  NOTIFICATION
  FOLLOW_UP
  REPLY
}

enum TaskCategory {
  GROWTH
  MARKETING
  OUTREACH
  PRODUCT
  ANALYTICS
  OPERATIONS
  RESEARCH
  ENGINEERING
  TWITTER
}

enum TaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum TweetQueueStatus {
  PENDING
  POSTED
  DELETED
}
